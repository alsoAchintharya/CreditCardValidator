<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/main"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="#F5F5F5"
tools:context=".MainActivity">

<androidx.cardview.widget.CardView
    android:id="@+id/creditCardView"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#1A237E"
    app:cardCornerRadius="16dp"
    app:cardElevation="20dp"
    app:layout_constraintDimensionRatio="H,1.58:1"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F1447"
        android:padding="20dp">

        <TextView
            android:id="@+id/bankname"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:gravity="center"
            android:text="BANK NAME HERE"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/cardChip"
            android:layout_width="45dp"
            android:layout_height="35dp"
            android:layout_marginTop="60dp"
            android:alpha="0.8"
            android:background="@drawable/chip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/cvv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="CVV"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <LinearLayout
            android:id="@+id/digitContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.6">

            <TextView
                android:id="@+id/digit1"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit2"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit3"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit4"
                style="@style/CardDigitWeight"
                android:layout_marginEnd="8dp"
                android:text="•" />

            <TextView
                android:id="@+id/digit5"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit6"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit7"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit8"
                style="@style/CardDigitWeight"
                android:layout_marginEnd="8dp"
                android:text="•" />

            <TextView
                android:id="@+id/digit9"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit10"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit11"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit12"
                style="@style/CardDigitWeight"
                android:layout_marginEnd="8dp"
                android:text="•" />

            <TextView
                android:id="@+id/digit13"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit14"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit15"
                style="@style/CardDigitWeight"
                android:text="•" />

            <TextView
                android:id="@+id/digit16"
                style="@style/CardDigitWeight"
                android:text="•" />
        </LinearLayout>


        <TextView
            android:id="@+id/expiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MM/YYYY"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/holderName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/digitContainer" />

        <TextView
            android:id="@+id/holderName"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="YOUR NAME HERE"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/brandLogo"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:textSize="17sp"
            android:textColor="@color/white"
            android:alpha="0.8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>

<EditText
    android:id="@+id/cardnumber"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="32dp"
    android:layout_marginTop="32dp"
    android:background="@android:drawable/editbox_background"
    android:hint="Enter 16 digit card number"
    android:inputType="number"
    android:maxLength="16"
    android:padding="16dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/creditCardView" />

<EditText
    android:id="@+id/namenter"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="32dp"
    android:layout_marginTop="16dp"
    android:background="@android:drawable/editbox_background"
    android:hint="Enter Card holder name"
    android:inputType="textPersonName"
    android:maxLength="20"
    android:padding="16dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/cardnumber" />

    <EditText
        android:id="@+id/cvventer"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="72dp"
        android:background="@android:drawable/editbox_background"
        android:hint="Enter CVV"
        android:inputType="number"
        android:maxLength="3"
        android:padding="16dp"
        app:layout_constraintStart_toEndOf="@id/expenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/namenter" />

    <EditText
        android:id="@+id/expenter"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:layout_marginStart="72dp"
        android:layout_marginTop="16dp"
        android:background="@android:drawable/editbox_background"
        android:clickable="true"
        android:focusable="false"
        android:hint="Expiry"
        android:padding="16dp"
        app:layout_constraintEnd_toStartOf="@id/cvventer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/namenter" />


</androidx.constraintlayout.widget.ConstraintLayout>
